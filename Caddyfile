# Caddyfile
# Since you are using Tailscale, your connection is ALREADY encrypted by WireGuard!
# We don't need a self-signed HTTPS certificate (which just causes browser warnings).
# Caddy will listen on port 80 and route traffic cleanly on your Tailscale IP.

:80 {
    # Route 1: Backend API
    handle /api/* {
        reverse_proxy localhost:3001
    }

    # Route 2: Mobile PWA 
    handle /* {
        reverse_proxy localhost:3002
    }
}
