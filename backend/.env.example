# Server Configuration
NODE_ENV=development
PORT=80
HOST=0.0.0.0

# OpenWeather API (Required for weather widget)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# NewsAPI (Optional)
NEWSAPI_KEY=your_news_api_key_here

# YouTube Data API (Required for Fun Page Stephen Curry highlights)
YOUTUBE_API_KEY=your_youtube_data_api_key_here
FUN_VIDEO_QUERY=Stephen Curry highlights
FUN_VIDEO_MAX_RESULTS=10
FUN_VIDEO_ROTATION_SECONDS=90
FUN_VIDEO_MIN_DURATION_SECONDS=90
FUN_VIDEO_ALLOWED_CHANNELS=ESPN,Golden State Warriors,Golden Hoops

# Spotify (Required for Spotify widget / pages)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost/api/spotify/callback

# Tom Tom API (Optional - required for traffic widget)
TOMTOM_API_KEY=your_tomtom_api_key_here

# Bible API (Optional)
ESV_API_KEY=your_esv_api_key_here

# Photos
PHOTOS_DIR=/app/data/photos
MAX_PHOTOS=100

# DHT22 Sensor
DHT22_GPIO_PIN=4
SENSOR_INTERVAL=60000

# Logging
LOG_LEVEL=info

# Power Control
POWER_TOKEN=your_power_token_here

# Internal service API key for trusted local services
API_KEY=super-secret-api-key

# Admin Password (Required for PWA dashboard)
ADMIN_PASSWORD=your_admin_password_here

# Auth secret for admin authentication (Random string)
AUTH_SECRET=a_very_long_and_secure_random_string

# ESP32 MQTT configuration
MQTT_USERNAME=smartmirror
MQTT_PASSWORD=your_mqtt_password_here
